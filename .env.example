# =============================================================
# Clube Auto+ BFF — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env.
# =============================================================

# Ambiente
NODE_ENV=development
PORT=3001

# Siprov — credenciais da conta da empresa (nunca expor no frontend)
SIPROV_BASE_URL=https://acesso.siprov.com.br/siprov-api
SIPROV_USERNAME=
SIPROV_PASSWORD=

# CORS — domínio do frontend (sem barra no final)
# Desenvolvimento:  http://localhost:3000  (porta configurada no vite.config.ts)
# Produção:        https://clubeautoplus.com.br
FRONTEND_URL=http://localhost:3000

# Sessão da Área do Cliente — chave de assinatura JWT
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# Tempo de expiração da sessão do cliente (em segundos). Padrão: 24h
SESSION_TTL_SECONDS=86400

# Painel de Gestão — credenciais de acesso ao painel interno (/gestao)
# Escolha um usuário e senha seguros. Nunca use as credenciais do Siprov aqui.
GESTAO_USERNAME=seu@email.com
GESTAO_PASSWORD=SuaSenhaForte123!
GESTAO_NOME=Seu Nome
