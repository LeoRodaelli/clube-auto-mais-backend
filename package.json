    "@fastify/sensible": "^6.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "pino-pretty": "^13.1.3",
